# Environment Variables Template
# Copy this to .env in the backend directory and fill in your values

# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.mongodb.net/forts_app?retryWrites=true&w=majority

# JWT Secret Key
# Generate a random string using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET - Don't share it!
JWT_SECRET=your_super_secret_random_key_change_this_to_something_very_secure_in_production_12345

# Server Port
PORT=5000

# Environment
# Set to 'production' when deploying to server
NODE_ENV=development
